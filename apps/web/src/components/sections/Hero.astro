---
import Container from '../layout/Container.astro';
import { getLocaleFromUrl, t, tList, type Locale } from '../../i18n';
const locale: Locale = getLocaleFromUrl(Astro.url);
const metaArr = tList(locale, 'hero.meta');
const dotClasses = ['', 'v', 'p'];

// Split title around the highlighted word so we can wrap it in a gradient span
const titleFull = t(locale, 'hero.title');
const titleWord = t(locale, 'hero.title_word');
const wordIdx = titleFull.indexOf(titleWord);
const titlePre = wordIdx >= 0 ? titleFull.slice(0, wordIdx) : titleFull;
const titlePost = wordIdx >= 0 ? titleFull.slice(wordIdx + titleWord.length) : '';
const subtitle = t(locale, 'hero.subtitle');
---

<section class="tcw-hero wrap" id="top">
  <Container>
    <div class="tcw-hero__grid">
      <div class="tcw-hero__copy reveal">
        <span class="eyebrow mono">{t(locale, 'hero.eyebrow')}</span>
        <h1 class="tcw-hero__title">
          {titlePre}<span class="word grad-text">{titleWord}</span>{titlePost}<br />{subtitle}
        </h1>
        <p class="tcw-hero__lead lead">{t(locale, 'hero.lead')}</p>
        <div class="tcw-hero__ctas cta-row">
          <a class="tcw-btn tcw-btn--cyan btn primary" href="#cta">
            {t(locale, 'hero.cta_primary')}
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"></path></svg
            >
          </a>
          <a class="tcw-btn tcw-btn--ghost btn ghost" href="#case">
            {t(locale, 'hero.cta_secondary')}
          </a>
        </div>
        <div class="tcw-hero__pills pills">
          {
            metaArr.map((m, i) => (
              <span class="tcw-pill pill mono">
                <span class={`tcw-pill__dot dot ${dotClasses[i % 3]}`} />
                {m}
              </span>
            ))
          }
        </div>
      </div>

      <div class="tcw-hero__console console glass reveal">
        <div class="tcw-hero__console-head console-head">
          <div class="tcw-hero__dots dots">
            <i></i><i></i><i></i>
          </div>
          <span class="tcw-hero__console-title title mono">agent.console</span>
          <span class="tcw-hero__console-live live mono">LIVE</span>
        </div>

        <div class="bubble in b1">
          <span class="meta">cliente · whatsapp</span>
          Hola, ¿tenéis cita esta semana para un corte y color?
        </div>
        <div class="bubble out b2">
          <span class="meta">agent · gpt-4o</span>
          ¡Claro! Tengo jueves 17:30 o viernes 11:00 con María. ¿Cuál te encaja?
        </div>
        <div class="bubble in b3">
          <span class="meta">cliente · whatsapp</span>
          Viernes 11h perfecto.
        </div>
        <div class="bubble out b4">
          <span class="meta">agent · gpt-4o</span>
          Reservado. Te envío recordatorio el jueves a las 19h.
        </div>

        <div class="lead-card">
          <div class="ic">+1</div>
          <div class="txt">
            <b>Lead creado en CRM</b>
            <span class="mono">booking · 0:42s · auto-routed</span>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .tcw-hero {
    padding: 88px 0 60px;
    position: relative;
  }
  .tcw-hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 60px;
    align-items: center;
  }
  @media (max-width: 980px) {
    .tcw-hero__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
  .tcw-hero__title {
    font-family: var(--font-sans);
    letter-spacing: -0.02em;
    line-height: 1.05;
    font-size: clamp(42px, 6.5vw, 84px);
    font-weight: 800;
    margin: 18px 0 22px;
    color: var(--ink);
  }
  .tcw-hero__title .word {
    display: inline-block;
  }
  .tcw-hero__lead {
    font-size: 19px;
    color: var(--muted);
    max-width: 60ch;
    line-height: 1.6;
  }
  .tcw-hero__ctas {
    display: flex;
    gap: 14px;
    margin: 30px 0 22px;
    flex-wrap: wrap;
  }
  .tcw-hero__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
  }
  .tcw-pill {
    padding: 7px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    border: var(--glass-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    font-size: 12px;
    color: var(--muted);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
  }
  .tcw-pill__dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--neon-cyan);
    margin-right: 8px;
    box-shadow: 0 0 12px var(--neon-cyan);
  }
  .tcw-pill__dot.v {
    background: var(--neon-violet);
    box-shadow: 0 0 12px var(--neon-violet);
  }
  .tcw-pill__dot.p {
    background: var(--neon-pink);
    box-shadow: 0 0 12px var(--neon-pink);
  }

  /* console card */
  .tcw-hero__console {
    padding: 24px;
    border-radius: var(--r-xl);
    position: relative;
    overflow: hidden;
  }
  .tcw-hero__console::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: var(--r-xl);
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(34, 211, 238, 0.6),
      rgba(167, 139, 250, 0.4),
      rgba(240, 171, 252, 0.4)
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
  .tcw-hero__console-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }
  .tcw-hero__dots {
    display: flex;
    gap: 6px;
  }
  .tcw-hero__dots i {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
    display: block;
  }
  .tcw-hero__dots i:nth-child(1) {
    background: #fb7185;
  }
  .tcw-hero__dots i:nth-child(2) {
    background: #fbbf24;
  }
  .tcw-hero__dots i:nth-child(3) {
    background: #34d399;
  }
  .tcw-hero__console-title {
    font-size: 12px;
    color: var(--dim);
  }
  .tcw-hero__console-live {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: var(--soft-cyan);
  }
  .tcw-hero__console-live::before {
    content: '';
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--soft-cyan);
    box-shadow: 0 0 10px var(--soft-cyan);
    animation: pulse 1.6s ease-in-out infinite;
  }
  .lead-card {
    margin-top: 14px;
    padding: 12px 14px;
    border-radius: 12px;
    background: linear-gradient(
      135deg,
      rgba(34, 211, 238, 0.12),
      rgba(167, 139, 250, 0.08)
    );
    border: 1px solid rgba(34, 211, 238, 0.3);
    display: flex;
    align-items: center;
    gap: 12px;
    opacity: 0;
    animation: bubIn 0.6s ease-out 3.4s forwards;
  }
  .lead-card .ic {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--grad-button);
    display: grid;
    place-items: center;
    color: #0b0a1f;
    font-weight: 800;
    font-size: 13px;
  }
  .lead-card .txt {
    font-size: 13px;
  }
  .lead-card .txt b {
    display: block;
    color: var(--ink);
  }
  .lead-card .txt span {
    color: var(--dim);
    font-size: 11px;
  }
</style>
