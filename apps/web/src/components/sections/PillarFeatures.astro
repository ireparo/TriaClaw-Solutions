---
interface Feature {
  icon: string;
  title: string;
  desc: string;
}
interface Props {
  title: string;
  features: Feature[];
}
const { title, features } = Astro.props;
---

<section class="py-24">
  <div class="mx-auto max-w-[1200px] px-8">
    <h2 class="text-3xl md:text-4xl font-extrabold text-navy tracking-tight mb-10 text-center">
      {title}
    </h2>
    <div class="grid md:grid-cols-3 gap-5">
      {
        features.map((f) => (
          <div class="bg-white border border-line rounded-2xl p-6">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="text-lg font-bold text-navy mb-2">{f.title}</h3>
            <p class="text-[14px] text-muted leading-relaxed">{f.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
