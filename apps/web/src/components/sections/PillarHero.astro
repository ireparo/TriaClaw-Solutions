---
type Tone = 'navy' | 'cyan' | 'teal';
interface Props {
  tone: Tone;
  eyebrow: string;
  title: string;
  subtitle: string;
  lead: string;
  ctaPrimary: { text: string; href: string };
  ctaSecondary: { text: string; href: string };
}
const { tone, eyebrow, title, subtitle, lead, ctaPrimary, ctaSecondary } = Astro.props;
const accent =
  tone === 'navy'
    ? 'var(--neon-violet)'
    : tone === 'cyan'
      ? 'var(--neon-cyan)'
      : 'var(--soft-cyan)';
---

<section class="tcw-pillar-hero" style={`--accent:${accent}`}>
  <div class="tcw-pillar-hero__inner">
    <div class="reveal">
      <span class="eyebrow mono">{eyebrow}</span>
      <h1 class="tcw-pillar-hero__title">
        <span class="grad-text">{title}</span>
      </h1>
      <p class="tcw-pillar-hero__subtitle">{subtitle}</p>
      <p class="tcw-pillar-hero__lead">{lead}</p>
      <div class="tcw-pillar-hero__ctas">
        <a class="tcw-btn tcw-btn--cyan" href={ctaPrimary.href}>{ctaPrimary.text}</a>
        <a class="tcw-btn tcw-btn--ghost" href={ctaSecondary.href}>{ctaSecondary.text}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .tcw-pillar-hero {
    padding: 88px 0 72px;
    position: relative;
  }
  .tcw-pillar-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      900px 400px at 30% 0%,
      color-mix(in srgb, var(--accent) 28%, transparent),
      transparent 70%
    );
    pointer-events: none;
    z-index: -1;
  }
  .tcw-pillar-hero__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .tcw-pillar-hero__title {
    font-family: var(--font-sans);
    font-size: clamp(42px, 6vw, 76px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 18px 0 22px;
    max-width: 18ch;
  }
  .tcw-pillar-hero__subtitle {
    font-size: 22px;
    color: var(--ink);
    max-width: 56ch;
    margin-bottom: 14px;
    line-height: 1.45;
  }
  .tcw-pillar-hero__lead {
    color: var(--muted);
    font-size: 17px;
    max-width: 60ch;
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .tcw-pillar-hero__ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
</style>
