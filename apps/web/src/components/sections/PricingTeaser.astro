---
import Container from '../layout/Container.astro';
import Button from '../ui/Button.astro';
import { getLocaleFromUrl, t, localizedHref, type Locale } from '../../i18n';
const locale: Locale = getLocaleFromUrl(Astro.url);
const from = t(locale, 'pricing_teaser.from');
const chips = [
  { icon: '📞', name: t(locale, 'pricing_teaser.chip_centralita'), price: '29 €/mes' },
  { icon: '🤖', name: t(locale, 'pricing_teaser.chip_agents'), price: '49 €/mes' },
  { icon: '📋', name: t(locale, 'pricing_teaser.chip_crm'), price: '39 €/usuario/mes' },
];
---

<section class="py-24">
  <Container class="text-center">
    <span
      class="inline-block px-3.5 py-1.5 bg-navy/[8%] text-navy rounded-full text-xs font-semibold tracking-wide mb-3"
      >{t(locale, 'pricing_teaser.eyebrow')}</span
    >
    <h2 class="text-4xl md:text-5xl font-extrabold text-navy tracking-tight mb-3">
      {t(locale, 'pricing_teaser.title')}
    </h2>
    <p class="text-lg text-muted max-w-2xl mx-auto mb-10">
      {t(locale, 'pricing_teaser.lead')}
    </p>
    <div class="flex justify-center gap-3 flex-wrap mb-6">
      {
        chips.map((c) => (
          <div class="px-5 py-3.5 border border-line rounded-xl bg-white text-[14.5px]">
            {c.icon} <strong class="text-navy font-bold">{c.name}</strong> · {from} {c.price}
          </div>
        ))
      }
    </div>
    <Button variant="navy" href={localizedHref(locale, '/precios')}
      >{t(locale, 'pricing_teaser.cta_table')}</Button
    >
    <p class="text-[13.5px] text-muted mt-4">{t(locale, 'pricing_teaser.note')}</p>
  </Container>
</section>
