---
import Container from '../layout/Container.astro';
import { getLocaleFromUrl, t, tList, localizedHref, type Locale } from '../../i18n';
const locale: Locale = getLocaleFromUrl(Astro.url);
const pillars = [
  {
    cls: 'c1',
    title: t(locale, 'pillars.centralita_title'),
    desc: t(locale, 'pillars.centralita_desc'),
    bullets: tList(locale, 'pillars.centralita_bullets'),
    href: '/centralita',
    cta: t(locale, 'pillars.centralita_cta'),
    icon: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>`,
  },
  {
    cls: 'c2',
    title: t(locale, 'pillars.agents_title'),
    desc: t(locale, 'pillars.agents_desc'),
    bullets: tList(locale, 'pillars.agents_bullets'),
    href: '/agents',
    cta: t(locale, 'pillars.agents_cta'),
    icon: `<rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4M8 16h.01M16 16h.01"/>`,
  },
  {
    cls: 'c3',
    title: t(locale, 'pillars.crm_title'),
    desc: t(locale, 'pillars.crm_desc'),
    bullets: tList(locale, 'pillars.crm_bullets'),
    href: '/crm',
    cta: t(locale, 'pillars.crm_cta'),
    icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M20 8v6M23 11h-6"/>`,
  },
];
---

<section class="tcw-section" id="pillars">
  <Container>
    <div class="tcw-section-head reveal">
      <span class="eyebrow mono">{t(locale, 'pillars.eyebrow')}</span>
      <h2 class="tcw-h2 grad-text">{t(locale, 'pillars.title')}</h2>
      <p class="tcw-section-head__lead">{t(locale, 'pillars.lead')}</p>
    </div>

    <div class="tcw-pillars">
      {
        pillars.map((p) => (
          <article class={`tcw-pcard glass ${p.cls} reveal`}>
            <div class="tcw-pcard__icn">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={p.icon}
              />
            </div>
            <h3 class="tcw-pcard__title">{p.title}</h3>
            <p class="tcw-pcard__desc">{p.desc}</p>
            <ul class="tcw-pcard__list">
              {p.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
            <a class="tcw-pcard__more" href={localizedHref(locale, p.href)}>
              {p.cta} →
            </a>
          </article>
        ))
      }
    </div>
  </Container>
</section>

<style is:global>
  /* shared section + h2 helpers used across the redesigned sections */
  .tcw-section {
    padding: 96px 0;
    position: relative;
  }
  .tcw-section-head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 8px;
  }
  .tcw-section-head h2 {
    margin-top: 14px;
  }
  .tcw-section-head__lead {
    color: var(--muted);
    font-size: 17px;
    margin-top: 14px;
    line-height: 1.6;
  }
  .tcw-h2 {
    font-family: var(--font-sans);
    letter-spacing: -0.02em;
    line-height: 1.05;
    font-size: clamp(34px, 4.6vw, 60px);
    font-weight: 800;
    color: var(--ink);
  }
  .tcw-h2 .grad-text {
    display: inline-block;
  }
</style>
<style>
  .tcw-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-top: 48px;
  }
  @media (max-width: 900px) {
    .tcw-pillars {
      grid-template-columns: 1fr;
    }
  }
  .tcw-pcard {
    position: relative;
    padding: 30px;
    border-radius: var(--r-xl);
    overflow: hidden;
    transition: 0.35s;
  }
  .tcw-pcard::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--r-xl);
    background: radial-gradient(circle at 20% 0%, var(--tint, rgba(167, 139, 250, 0.16)), transparent 60%);
    pointer-events: none;
  }
  .tcw-pcard:hover {
    transform: translateY(-6px) scale(1.01);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.15),
      0 30px 80px -20px rgba(167, 139, 250, 0.5);
  }
  .tcw-pcard::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: var(--r-xl);
    padding: 1px;
    opacity: 0;
    transition: 0.35s;
    background: linear-gradient(135deg, var(--neon-cyan), var(--neon-violet), var(--neon-pink));
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
  .tcw-pcard:hover::before {
    opacity: 1;
  }
  .tcw-pcard.c1 {
    --tint: rgba(34, 211, 238, 0.18);
  }
  .tcw-pcard.c2 {
    --tint: rgba(103, 232, 249, 0.16);
  }
  .tcw-pcard.c3 {
    --tint: rgba(240, 171, 252, 0.16);
  }
  .tcw-pcard__icn {
    width: 54px;
    height: 54px;
    border-radius: 16px;
    display: grid;
    place-items: center;
    margin-bottom: 18px;
    background: var(--grad-button);
    box-shadow: 0 0 30px -8px rgba(34, 211, 238, 0.6);
    color: #0b0a1f;
    position: relative;
    z-index: 1;
  }
  .tcw-pcard__icn svg {
    width: 26px;
    height: 26px;
  }
  .tcw-pcard__title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
    color: var(--ink);
    position: relative;
    z-index: 1;
  }
  .tcw-pcard__desc {
    color: var(--muted);
    font-size: 15px;
    margin-bottom: 18px;
    line-height: 1.6;
    position: relative;
    z-index: 1;
  }
  .tcw-pcard__list {
    list-style: none;
    display: grid;
    gap: 8px;
    margin-bottom: 22px;
    padding: 0;
    position: relative;
    z-index: 1;
  }
  .tcw-pcard__list li {
    font-size: 14px;
    color: var(--muted);
    padding-left: 22px;
    position: relative;
    line-height: 1.45;
  }
  .tcw-pcard__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--grad-button);
    box-shadow: 0 0 10px rgba(34, 211, 238, 0.5);
  }
  .tcw-pcard__more {
    font-weight: 600;
    font-size: 14px;
    color: var(--neon-cyan);
    position: relative;
    z-index: 1;
    transition: 0.2s;
    text-decoration: none;
    display: inline-block;
  }
  .tcw-pcard__more:hover {
    color: var(--neon-violet);
    transform: translateX(4px);
  }
</style>
