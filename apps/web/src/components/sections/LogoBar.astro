---
import Container from '../layout/Container.astro';
import { getLocaleFromUrl, t, type Locale } from '../../i18n';
const locale: Locale = getLocaleFromUrl(Astro.url);
const logos = [
  { name: 'iReparo SAT' },
  { name: 'Lo Porró Carrincló' },
  { name: 'Ilercasa Asesoria' },
  { name: 'Mis Tesoros' },
];
---

<section class="tcw-logobar-wrap">
  <Container>
    <div class="tcw-logobar glass reveal">
      <span class="tcw-logobar__label mono">{t(locale, 'logobar.label')}</span>
      {logos.map((l) => <span class="tcw-logobar__name">{l.name}</span>)}
    </div>
  </Container>
</section>

<style>
  .tcw-logobar-wrap {
    padding: 30px 0;
  }
  .tcw-logobar {
    margin: 0 auto;
    padding: 22px 32px;
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
    justify-content: center;
    border-radius: var(--r-lg);
  }
  .tcw-logobar__label {
    font-size: 11px;
    color: var(--dim);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .tcw-logobar__name {
    font-weight: 600;
    color: var(--muted);
    font-size: 17px;
    letter-spacing: -0.01em;
    text-shadow: 0 0 24px rgba(167, 139, 250, 0.25);
    transition: 0.2s;
  }
  .tcw-logobar__name:hover {
    color: var(--ink);
    text-shadow: 0 0 32px rgba(167, 139, 250, 0.55);
  }
</style>
