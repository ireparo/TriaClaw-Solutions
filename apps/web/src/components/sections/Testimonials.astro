---
import Container from '../layout/Container.astro';
import Testimonial from '../ui/Testimonial.astro';
import { getLocaleFromUrl, t, type Locale } from '../../i18n';
const locale: Locale = getLocaleFromUrl(Astro.url);
const items = [
  {
    quote: t(locale, 'testimonials.quote1'),
    name: t(locale, 'testimonials.name1'),
    role: t(locale, 'testimonials.role1'),
  },
  {
    quote: t(locale, 'testimonials.quote2'),
    name: t(locale, 'testimonials.name2'),
    role: t(locale, 'testimonials.role2'),
  },
  {
    quote: t(locale, 'testimonials.quote3'),
    name: t(locale, 'testimonials.name3'),
    role: t(locale, 'testimonials.role3'),
  },
];
---

<section class="tcw-section">
  <Container>
    <div class="tcw-section-head reveal" style="text-align:center">
      <span class="eyebrow mono">{t(locale, 'testimonials.eyebrow')}</span>
      <h2 class="tcw-h2 grad-text">{t(locale, 'testimonials.title')}</h2>
      <p class="tcw-section-head__lead">{t(locale, 'testimonials.lead')}</p>
    </div>
    <div class="tcw-testimonials__grid">
      {items.map((it) => <Testimonial quote={it.quote} name={it.name} role={it.role} />)}
    </div>
  </Container>
</section>

<style>
  .tcw-testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 48px;
  }
  @media (max-width: 900px) {
    .tcw-testimonials__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
