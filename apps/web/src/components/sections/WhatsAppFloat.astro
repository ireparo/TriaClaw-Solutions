---
const wa = `https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER}`;
---

<a href={wa} class="tcw-fab" aria-label="Hablar por WhatsApp">
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path
      d="M20.52 3.48A11.94 11.94 0 0 0 12.07 0C5.5 0 .15 5.34.15 11.92c0 2.1.55 4.15 1.6 5.96L0 24l6.32-1.66a11.93 11.93 0 0 0 5.74 1.46h.01c6.58 0 11.92-5.34 11.92-11.92 0-3.18-1.24-6.18-3.47-8.4ZM12.07 21.8h-.01a9.86 9.86 0 0 1-5.03-1.38l-.36-.21-3.75.98 1-3.65-.24-.38a9.85 9.85 0 0 1-1.51-5.24c0-5.46 4.44-9.9 9.9-9.9 2.65 0 5.13 1.03 7 2.9a9.83 9.83 0 0 1 2.9 7c0 5.45-4.44 9.88-9.9 9.88Zm5.41-7.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.66.15-.2.3-.76.97-.93 1.17-.17.2-.34.22-.64.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.34.45-.51.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.66-1.6-.91-2.18-.24-.58-.49-.5-.66-.5h-.57c-.2 0-.51.07-.78.37-.27.3-1.03 1-1.03 2.45s1.06 2.85 1.21 3.05c.15.2 2.08 3.18 5.05 4.46.7.3 1.26.48 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35Z"
    ></path>
  </svg>
</a>

<style>
  .tcw-fab {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 60;
    width: 62px;
    height: 62px;
    border-radius: 50%;
    background: var(--whatsapp);
    display: grid;
    place-items: center;
    box-shadow:
      0 0 0 0 rgba(37, 211, 102, 0.55),
      0 18px 40px -10px rgba(37, 211, 102, 0.6);
    animation: waPulse 2.4s ease-out infinite;
    text-decoration: none;
    color: #fff;
  }
  .tcw-fab svg {
    width: 30px;
    height: 30px;
    color: #fff;
  }
</style>
