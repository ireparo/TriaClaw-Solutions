---
type Tone = 'default' | 'navy' | 'cyan' | 'teal';
interface Props {
  tone?: Tone;
  class?: string;
}
const { tone = 'default', class: cls = '' } = Astro.props;
const accent =
  tone === 'navy'
    ? 'rgba(167,139,250,.7)'
    : tone === 'cyan'
      ? 'rgba(34,211,238,.7)'
      : tone === 'teal'
        ? 'rgba(103,232,249,.7)'
        : '';
---

<div
  class={`glass tcw-card ${cls}`}
  data-tone={tone}
  style={accent ? `--accent:${accent}` : undefined}
>
  <slot />
</div>

<style is:global>
  .tcw-card {
    position: relative;
    border-radius: var(--r-lg);
    padding: 28px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .tcw-card:hover {
    transform: translateY(-4px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.15),
      0 24px 60px -20px rgba(167, 139, 250, 0.5);
  }
  .tcw-card[data-tone='navy']::after,
  .tcw-card[data-tone='cyan']::after,
  .tcw-card[data-tone='teal']::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    border-radius: var(--r-lg) var(--r-lg) 0 0;
    background: var(--accent);
    opacity: 0.8;
    pointer-events: none;
  }
</style>
