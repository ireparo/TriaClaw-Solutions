---
type Variant = 'default' | 'highlighted' | 'dark';
interface Props {
  pillarLabel: string;
  planName: string;
  price: string;
  priceSuffix?: string;
  features: string[];
  ctaText: string;
  ctaHref: string;
  variant?: Variant;
}
const {
  pillarLabel,
  planName,
  price,
  priceSuffix = '/mes',
  features,
  ctaText,
  ctaHref,
  variant = 'default',
} = Astro.props;
---

<div class={`tcw-pricing-card glass tcw-pricing-card--${variant}`}>
  {
    variant === 'highlighted' && (
      <span class="tcw-pricing-card__badge mono">RECOMENDADO</span>
    )
  }
  <span class="tcw-pricing-card__pill mono">{pillarLabel}</span>
  <h3 class="tcw-pricing-card__name">{planName}</h3>
  <div class="tcw-pricing-card__price">
    <span class="grad-text">{price}</span>
    <span class="tcw-pricing-card__suffix">{priceSuffix}</span>
  </div>
  <ul class="tcw-pricing-card__features">
    {features.map((f) => <li>{f}</li>)}
  </ul>
  <a href={ctaHref} class="tcw-pricing-card__cta">{ctaText}</a>
</div>

<style is:global>
  .tcw-pricing-card {
    position: relative;
    border-radius: var(--r-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .tcw-pricing-card--highlighted::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: var(--r-lg);
    padding: 1.5px;
    background: linear-gradient(135deg, #22d3ee, #a78bfa, #f0abfc);
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
  .tcw-pricing-card--dark {
    background: rgba(167, 139, 250, 0.12);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 0 80px -10px rgba(167, 139, 250, 0.6);
  }
  .tcw-pricing-card__badge {
    position: absolute;
    top: -12px;
    right: 18px;
    background: var(--grad-button);
    color: #0b0a1f;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
  }
  .tcw-pricing-card__pill {
    display: inline-block;
    align-self: flex-start;
    padding: 5px 12px;
    border-radius: 999px;
    background: rgba(34, 211, 238, 0.14);
    border: 1px solid rgba(34, 211, 238, 0.35);
    color: var(--soft-cyan);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .tcw-pricing-card__name {
    margin-top: 14px;
    font-size: 18px;
    font-weight: 700;
    color: var(--ink);
  }
  .tcw-pricing-card__price {
    font-family: var(--font-mono);
    font-size: 32px;
    font-weight: 600;
    margin: 6px 0 14px;
    line-height: 1;
  }
  .tcw-pricing-card__suffix {
    font-size: 13px;
    color: var(--dim);
    font-weight: 400;
    margin-left: 4px;
  }
  .tcw-pricing-card__features {
    list-style: none;
    padding: 0;
    margin: 0 0 22px;
    display: grid;
    gap: 8px;
    flex: 1;
  }
  .tcw-pricing-card__features li {
    font-size: 13.5px;
    color: var(--muted);
    padding-left: 22px;
    position: relative;
  }
  .tcw-pricing-card__features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--grad-button);
    box-shadow: 0 0 10px rgba(34, 211, 238, 0.5);
  }
  .tcw-pricing-card__cta {
    display: block;
    text-align: center;
    width: 100%;
    font-weight: 700;
    font-size: 13px;
    border-radius: 12px;
    padding: 12px 16px;
    background: var(--grad-button);
    color: #0b0a1f;
    transition: 0.25s;
    text-decoration: none;
  }
  .tcw-pricing-card__cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 30px -8px rgba(167, 139, 250, 0.7);
  }
  .tcw-pricing-card--default .tcw-pricing-card__cta {
    background: rgba(255, 255, 255, 0.06);
    color: var(--ink);
    border: var(--glass-border);
  }
</style>
