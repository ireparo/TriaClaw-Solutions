---
import Container from './Container.astro';
import { getLocaleFromUrl, t, localizedHref, type Locale } from '../../i18n';
const locale: Locale = getLocaleFromUrl(Astro.url);
---

<footer class="tcw-footer" id="footer">
  <Container>
    <div class="tcw-footer__grid">
      <div class="tcw-footer__brand">
        <img src="/logo-triaclaw.png" alt="TriaClaw" />
        <p>{t(locale, 'footer.tagline')}</p>
      </div>
      <div>
        <h5 class="mono">{t(locale, 'footer_columns.product')}</h5>
        <ul>
          <li><a href={localizedHref(locale, '/centralita')}>{t(locale, 'nav.centralita')}</a></li>
          <li><a href={localizedHref(locale, '/agents')}>{t(locale, 'nav.agents')}</a></li>
          <li><a href={localizedHref(locale, '/crm')}>{t(locale, 'nav.crm')}</a></li>
          <li><a href={localizedHref(locale, '/precios')}>{t(locale, 'nav.pricing')}</a></li>
        </ul>
      </div>
      <div>
        <h5 class="mono">{t(locale, 'footer_columns.company')}</h5>
        <ul>
          <li><a href={localizedHref(locale, '/casos')}>{t(locale, 'nav.cases')}</a></li>
          <li><a href={localizedHref(locale, '/partners')}>{t(locale, 'nav.partners')}</a></li>
          <li><a href={localizedHref(locale, '/sobre')}>{t(locale, 'footer_columns.about')}</a></li>
          <li><a href={localizedHref(locale, '/contacto')}>{t(locale, 'nav.contact')}</a></li>
        </ul>
      </div>
      <div>
        <h5 class="mono">{t(locale, 'footer_columns.resources')}</h5>
        <ul>
          <li><a href="/demos/">Demos</a></li>
          <li><a href={localizedHref(locale, '/contacto')}>{t(locale, 'footer_columns.support')}</a></li>
        </ul>
      </div>
      <div>
        <h5 class="mono">{t(locale, 'footer_columns.legal')}</h5>
        <ul>
          <li>
            <a href={localizedHref(locale, '/legal/privacidad')}
              >{t(locale, 'footer_columns.privacy')}</a
            >
          </li>
          <li>
            <a href={localizedHref(locale, '/legal/aviso')}
              >{t(locale, 'footer_columns.terms')}</a
            >
          </li>
          <li>
            <a href={localizedHref(locale, '/legal/cookies')}
              >{t(locale, 'footer_columns.cookies')}</a
            >
          </li>
        </ul>
      </div>
    </div>
    <div class="tcw-footer__bottom mono">
      <span>{t(locale, 'footer.rights')}</span>
      <span>
        <a href={`mailto:${t(locale, 'footer.email')}`}>{t(locale, 'footer.email')}</a> · {t(locale, 'footer.right_meta')}
      </span>
    </div>
  </Container>
</footer>

<style>
  .tcw-footer {
    margin-top: 60px;
    background: rgba(10, 8, 30, 0.55);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    position: relative;
    overflow: hidden;
    color: var(--muted);
  }
  .tcw-footer::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(rgba(255, 255, 255, 0.5) 1px, transparent 1px),
      radial-gradient(rgba(167, 139, 250, 0.4) 1px, transparent 1px);
    background-size:
      90px 90px,
      150px 150px;
    background-position:
      0 0,
      30px 50px;
    opacity: 0.18;
    pointer-events: none;
  }
  .tcw-footer__grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(4, 1fr);
    gap: 36px;
    padding: 60px 0 36px;
    position: relative;
  }
  @media (max-width: 900px) {
    .tcw-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
  }
  .tcw-footer__brand img {
    height: 40px;
    margin-bottom: 14px;
  }
  .tcw-footer__brand p {
    color: var(--muted);
    font-size: 14px;
    max-width: 32ch;
    line-height: 1.55;
  }
  .tcw-footer h5 {
    font-size: 11px;
    color: var(--dim);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 14px;
    font-weight: 600;
  }
  .tcw-footer ul {
    list-style: none;
    display: grid;
    gap: 10px;
    padding: 0;
    margin: 0;
  }
  .tcw-footer ul a {
    color: var(--muted);
    font-size: 14px;
    text-decoration: none;
    transition: 0.2s;
  }
  .tcw-footer ul a:hover {
    color: var(--ink);
  }
  .tcw-footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 22px 0;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 14px;
    font-size: 11px;
    color: var(--dim);
    position: relative;
  }
  .tcw-footer__bottom a {
    color: var(--muted);
    text-decoration: none;
  }
  .tcw-footer__bottom a:hover {
    color: var(--ink);
  }
</style>
